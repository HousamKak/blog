---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TagList from '../components/TagList.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags: string[];
  headings: { depth: number; slug: string; text: string }[];
  theme?: 'default' | 'pixel';
  lang?: 'en' | 'ar';
}

const { title, description, pubDate, updatedDate, heroImage, tags, headings, theme, lang } = Astro.props;
---
<BaseLayout title={title} description={description} ogImage={heroImage} theme={theme} lang={lang}>
  <div class="post-with-toc">
    <article class="py-4">
      {heroImage && (
        <img
          src={heroImage}
          alt=""
          class="mb-8 aspect-[2/1] w-full object-cover"
          style="border-radius: var(--radius-xl);"
          transition:name={`hero-${Astro.url.pathname}`}
        />
      )}

      <header class="mb-8">
        <h1 class="mb-3 text-3xl font-extrabold tracking-tight sm:text-4xl" style="font-family: var(--font-heading);" transition:name={`title-${Astro.url.pathname}`}>
          {title}
        </h1>
        <div class="flex flex-wrap items-center gap-3 text-sm text-[var(--color-muted)]">
          <FormattedDate date={pubDate} />
          {updatedDate && (
            <span>
              (updated <FormattedDate date={updatedDate} />)
            </span>
          )}
        </div>
        <div class="mt-3">
          <TagList tags={tags} />
        </div>
      </header>

      <!-- Inline TOC (visible on smaller screens) -->
      {headings.length > 0 && (
        <div class="mb-8">
          <TableOfContents headings={headings} />
        </div>
      )}

      <div class="prose">
        <slot />
      </div>
    </article>

    <!-- Sidebar TOC (visible on xl+ screens) -->
    {headings.length > 0 && (
      <TableOfContents headings={headings} sidebar />
    )}
  </div>
</BaseLayout>
