---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import BackLink from '../components/BackLink.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags: string[];
  headings: { depth: number; slug: string; text: string }[];
  theme?: 'default' | 'pixel';
  lang?: 'en' | 'ar';
  backHref?: string;
  backLabel?: string;
}

const { title, description, pubDate, updatedDate, heroImage, tags, headings, theme, lang, backHref = '/posts/', backLabel = 'All posts' } = Astro.props;

const kicker = tags.length > 0 ? tags.slice(0, 2).join(' • ').toUpperCase() : 'CORRESPONDENCE';
const dateLabel = pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }).toUpperCase();
---
<BaseLayout title={title} description={description} ogImage={heroImage} theme={theme} lang={lang}>
  <article class="broadsheet-article">
    <BackLink href={backHref} label={backLabel} />

    <div class="article-kicker">{kicker}</div>

    <h1 class="article-headline">{title}</h1>

    <p class="article-deck">{description}</p>

    <div class="article-byline">
      <span class="byline-by">BY</span>
      <span class="byline-author">HOUSAM KAK</span>
      <span class="byline-sep">—</span>
      <span class="byline-date">{dateLabel}</span>
      {updatedDate && (
        <span class="byline-update"> &nbsp;&bull;&nbsp; Revised <FormattedDate date={updatedDate} /></span>
      )}
    </div>

    {heroImage && (
      <figure class="article-hero">
        <img src={heroImage} alt="" transition:name={`hero-${Astro.url.pathname}`} />
        <figcaption>{description}</figcaption>
      </figure>
    )}

    <div class="article-columns prose">
      <slot />
    </div>

    {headings.length > 0 && (
      <aside class="article-toc-aside">
        <div class="toc-label">In this edition</div>
        <ul>
          {headings.filter(h => h.depth >= 2 && h.depth <= 3).map(h => (
            <li class:list={[`toc-depth-${h.depth}`]}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ul>
      </aside>
    )}

    <div class="article-footer">
      <div class="footer-rule"></div>
      <div class="footer-tags">FILED UNDER — {tags.map(t => t.toUpperCase()).join(' • ')}</div>
    </div>
  </article>
</BaseLayout>
