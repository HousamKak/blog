---
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  theme?: 'default' | 'pixel';
}

const { title, description = "Housam's personal blog", ogImage, theme = 'default' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pageTitle = title === 'Home' ? "Housam's Blog" : `${title} | Housam`;
const themeClass = theme !== 'default' ? `theme-${theme}` : '';
---
<!doctype html>
<html lang="en" class={themeClass} data-page-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/lib/wilson/wilson.min.css" />
    <link rel="alternate" type="application/rss+xml" title="Housam's Blog" href="/rss.xml" />

    <!-- Pixel theme font (only loaded when needed) -->
    {theme === 'pixel' && (
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet" />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site)} />}

    <!--
      Dark mode init — runs before first paint.
      Also restores after ViewTransitions swap (which replaces <html> attributes).
    -->
    <script is:inline>
      function applyDarkMode() {
        var mode = localStorage.getItem('theme') ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.classList.toggle('dark', mode === 'dark');
      }
      applyDarkMode();
      document.addEventListener('astro:after-swap', applyDarkMode);
    </script>

    <ViewTransitions />
  </head>
  <body>
    <!-- Ambient pixel decoration (hidden by CSS unless theme-pixel is on html) -->
    <canvas id="pixel-ambient" class="pixel-ambient"></canvas>

    <Header currentPath={Astro.url.pathname} />

    <div class="layout-grid">
      <aside class="layout-gutter-left"></aside>
      <main class="layout-content">
        <slot />
      </main>
      <aside class="layout-gutter-right"></aside>
    </div>

    <Footer />

    <!-- Ambient pixel starfield — only runs when theme-pixel is on html -->
    <script is:inline>
      function initPixelAmbient() {
        var canvas = document.getElementById('pixel-ambient');
        if (!canvas) return;
        var ctx = canvas.getContext('2d');
        if (!ctx) return;

        var stars = [];
        var raf = 0;
        var active = false;

        function resize() {
          canvas.width = window.innerWidth;
          canvas.height = window.innerHeight;
        }

        function createStars() {
          stars = [];
          for (var i = 0; i < 60; i++) {
            stars.push({
              x: Math.random() * canvas.width,
              y: Math.random() * canvas.height,
              size: Math.random() < 0.3 ? 3 : (Math.random() < 0.6 ? 2 : 1),
              speed: 0.2 + Math.random() * 0.5,
              brightness: 0.3 + Math.random() * 0.7,
              twinkleSpeed: 0.005 + Math.random() * 0.02,
              twinklePhase: Math.random() * Math.PI * 2,
            });
          }
        }

        function draw(time) {
          if (!active) return;
          ctx.clearRect(0, 0, canvas.width, canvas.height);

          var isDark = document.documentElement.classList.contains('dark');

          for (var i = 0; i < stars.length; i++) {
            var s = stars[i];
            s.y += s.speed;
            if (s.y > canvas.height + 4) {
              s.y = -4;
              s.x = Math.random() * canvas.width;
            }
            var twinkle = 0.5 + 0.5 * Math.sin(time * s.twinkleSpeed + s.twinklePhase);
            var alpha = s.brightness * twinkle * (isDark ? 0.6 : 0.25);
            ctx.fillStyle = isDark
              ? 'rgba(200, 200, 255, ' + alpha + ')'
              : 'rgba(50, 50, 100, ' + alpha + ')';
            ctx.fillRect(Math.floor(s.x), Math.floor(s.y), s.size, s.size);
          }

          raf = requestAnimationFrame(draw);
        }

        function start() {
          if (active) return;
          active = true;
          resize();
          createStars();
          raf = requestAnimationFrame(draw);
        }

        function stop() {
          active = false;
          cancelAnimationFrame(raf);
          if (ctx) ctx.clearRect(0, 0, canvas.width, canvas.height);
        }

        function check() {
          var isPixel = document.documentElement.classList.contains('theme-pixel');
          if (isPixel && !active) start();
          else if (!isPixel && active) stop();
        }

        window.addEventListener('resize', function() {
          if (active) { resize(); createStars(); }
        });

        var observer = new MutationObserver(check);
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

        check();
      }

      initPixelAmbient();
      document.addEventListener('astro:after-swap', function() {
        setTimeout(initPixelAmbient, 50);
      });
    </script>
  </body>
</html>
