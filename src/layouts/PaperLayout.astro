---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TagList from '../components/TagList.astro';
import PdfEmbed from '../components/PdfEmbed.astro';
import BackLink from '../components/BackLink.astro';

interface Publication {
  name: string;
  url?: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  authors: string[];
  pdfUrl: string;
  venue?: string;
  doi?: string;
  publications?: Publication[];
  tags: string[];
  theme?: 'default' | 'pixel';
  lang?: 'en' | 'ar';
}

const { title, description, pubDate, authors, pdfUrl, venue, doi, publications = [], tags, theme, lang } = Astro.props;
---
<BaseLayout title={title} description={description} theme={theme} lang={lang}>
  <article class="chaos-article">
    <div class="article-main">
      <BackLink href="/papers/" label="All papers" />

      <div class="article-kicker">Paper · {venue || 'Working Paper'}</div>
      <h1 class="article-headline">{title}</h1>
      <p class="article-deck">{description}</p>

      <div class="article-byline">
        <span class="byline-by">BY</span>
        <span class="byline-author">{authors.map(a => a.toUpperCase()).join(' · ')}</span>
        <span class="byline-sep">—</span>
        <FormattedDate date={pubDate} />
        {doi && (
          <>
            <span class="byline-sep">—</span>
            <a href={`https://doi.org/${doi}`} target="_blank" rel="noopener" style="color: var(--ink-red); text-decoration: none; border-bottom: 1px dotted var(--ink-red);">DOI ↗</a>
          </>
        )}
      </div>

      <div style="margin-bottom: 1.5rem;">
        <TagList tags={tags} />
      </div>

      <!-- Abstract + Publications as side-by-side pinned notes -->
      <section class="paper-meta-grid">
        <div class="chaos-card tilted-l">
          <span class="tape tl" aria-hidden="true"></span>
          <div class="chaos-kicker">Abstract</div>
          <p style="font-family: var(--font-body); font-size: 1.05rem; line-height: 1.65; margin: 0;">{description}</p>
        </div>

        <div class="chaos-card tilted-r">
          <span class="tape tr" aria-hidden="true"></span>
          <div class="chaos-kicker blue">Publications</div>
          {publications.length === 0 ? (
            <p style="font-family: var(--font-typewriter); font-size: 0.95rem; color: var(--ink-muted); margin: 0;">Not yet filed.</p>
          ) : (
            <ul style="list-style: none; padding: 0; margin: 0; font-family: var(--font-typewriter); font-size: 0.95rem; line-height: 1.7;">
              {publications.map(pub => (
                <li style="padding: 0.25rem 0; border-bottom: 1px dotted var(--color-hairline);">
                  {pub.url ? (
                    <a href={pub.url} target="_blank" rel="noopener" style="color: var(--ink-red); text-decoration: none; border-bottom: 1px dotted var(--ink-red);">
                      {pub.name} ↗
                    </a>
                  ) : (
                    <span>{pub.name}</span>
                  )}
                </li>
              ))}
            </ul>
          )}
        </div>
      </section>

      <div style="margin: 2rem 0 1rem;">
        <div class="chaos-kicker" style="display: inline-block; margin-bottom: 1rem;">Full text</div>
        <PdfEmbed url={pdfUrl} title={title} />
      </div>

      <div class="article-columns prose">
        <slot />
      </div>

      <div class="article-footer">
        <div class="footer-rule"></div>
        <div class="footer-tags">FILED UNDER — {tags.map(t => t.toUpperCase()).join(' • ')}</div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .paper-meta-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin: 1.5rem 0 2rem;
  }
  @media (min-width: 720px) {
    .paper-meta-grid { grid-template-columns: 1.4fr 1fr; }
  }
</style>
