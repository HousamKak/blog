---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import NoteCard from '../../components/NoteCard.astro';
import PaperCard from '../../components/PaperCard.astro';
import RenderCard from '../../components/RenderCard.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const allPapers = await getCollection('papers');
  const allNotes = await getCollection('notes');
  const allRenders = await getCollection('renders');

  const allItems = [...allPosts, ...allPapers, ...allNotes, ...allRenders]
    .filter(item => !item.data.draft);

  const tags = [...new Set(allItems.flatMap(item => item.data.tags))];

  return tags.map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: allPosts.filter(p => !p.data.draft && p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
      papers: allPapers.filter(p => !p.data.draft && p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
      notes: allNotes.filter(n => !n.data.draft && n.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
      renders: allRenders.filter(r => !r.data.draft && r.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts, papers, notes, renders } = Astro.props;
---
<BaseLayout title={`Tag: ${tag}`} description={`Content tagged with "${tag}".`}>
  <h1 class="mb-8 text-3xl font-extrabold tracking-tight">
    Tagged: <span class="text-[var(--color-accent)]">{tag}</span>
  </h1>

  {posts.length > 0 && (
    <section class="mb-10">
      <h2 class="mb-4 text-xl font-bold">Posts</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {posts.map((post: any) => (
          <PostCard
            id={post.id}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            heroImage={post.data.heroImage}
            tags={post.data.tags}
          />
        ))}
      </div>
    </section>
  )}

  {papers.length > 0 && (
    <section class="mb-10">
      <h2 class="mb-4 text-xl font-bold">Papers</h2>
      <div class="grid gap-4">
        {papers.map((paper: any) => (
          <PaperCard
            id={paper.id}
            title={paper.data.title}
            description={paper.data.description}
            pubDate={paper.data.pubDate}
            authors={paper.data.authors}
            venue={paper.data.venue}
            pdfUrl={paper.data.pdfUrl}
            tags={paper.data.tags}
          />
        ))}
      </div>
    </section>
  )}

  {notes.length > 0 && (
    <section class="mb-10">
      <h2 class="mb-4 text-xl font-bold">Notes</h2>
      <div class="grid gap-2">
        {notes.map((note: any) => (
          <NoteCard
            id={note.id}
            title={note.data.title}
            pubDate={note.data.pubDate}
            tags={note.data.tags}
          />
        ))}
      </div>
    </section>
  )}

  {renders.length > 0 && (
    <section class="mb-10">
      <h2 class="mb-4 text-xl font-bold">Renders</h2>
      <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
        {renders.map((render: any) => (
          <RenderCard
            id={render.id}
            title={render.data.title}
            thumbnail={render.data.thumbnail}
            mediaType={render.data.mediaType}
            software={render.data.software}
          />
        ))}
      </div>
    </section>
  )}

</BaseLayout>
