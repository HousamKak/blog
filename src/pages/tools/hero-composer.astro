---
// Dev tool: multi-layer image composer.
//   - Add N layers. Each is an image + mode (cover canvas / placed at x,y,w).
//   - Sources come from the built-in gallery (public/media/** via /api/list-media)
//     or from uploads (drag-drop or file picker). Uploads can optionally be
//     persisted to public/media/uploads/ so they survive a reload.
//   - Each layer can be wrapped in a cream paper "panel" (configurable padding,
//     colors, border, shadow, corner radius) — handy for reading-mat treatments.
//   - Drag layers directly on the canvas to reposition. Shift-drag = 1% snap.
//   - Reorder, hide, delete, duplicate layers.
//   - Save writes the composed PNG to public/media/<dir>/<file>. Download works
//     anywhere.
//
// All server endpoints used here are attached via a Vite dev middleware only
// (see astro.config.mjs), so nothing here affects the production static build.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Hero composer</title>
    <style>
      :root {
        --bg: #14110c;
        --panel: #1f1b14;
        --panel-2: #2a2418;
        --ink: #e8dec5;
        --ink-muted: #968a6e;
        --accent: #e36363;
        --accent-2: #78c07a;
        --hairline: #3a3325;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; background: var(--bg); color: var(--ink); font-family: ui-sans-serif, system-ui, -apple-system, sans-serif; }
      body { min-height: 100dvh; display: flex; }
      code { font-family: ui-monospace, 'JetBrains Mono', monospace; font-size: 0.85em; }

      .sidebar {
        width: 360px; min-width: 360px; padding: 1.1rem 1.1rem 2rem;
        background: var(--panel); border-right: 1px solid var(--hairline);
        overflow-y: auto; height: 100dvh;
      }
      .sidebar h1 { font-size: 1.05rem; margin: 0 0 0.2rem; }
      .sidebar .sub { font-size: 0.76rem; color: var(--ink-muted); margin-bottom: 1rem; }
      .group { margin-bottom: 1rem; padding-bottom: 0.9rem; border-bottom: 1px dashed var(--hairline); }
      .group:last-child { border-bottom: none; }
      .group-label { font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 0.5rem; }

      .row { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.4rem; }
      .row label { flex: 0 0 92px; font-size: 0.76rem; color: var(--ink); }
      .row input[type="range"] { flex: 1; min-width: 0; }
      .row input[type="number"] { width: 72px; background: #0f0d08; color: var(--ink); border: 1px solid var(--hairline); border-radius: 4px; padding: 4px 6px; font: inherit; font-size: 0.78rem; }
      .row input[type="text"] { flex: 1; min-width: 0; background: #0f0d08; color: var(--ink); border: 1px solid var(--hairline); border-radius: 4px; padding: 4px 6px; font: inherit; font-size: 0.78rem; }
      .row input[type="color"] { width: 44px; height: 26px; padding: 0; border: 1px solid var(--hairline); background: transparent; cursor: pointer; }
      .row input[type="checkbox"] { accent-color: var(--accent); transform: scale(1.1); }
      .row select { flex: 1; background: #0f0d08; color: var(--ink); border: 1px solid var(--hairline); border-radius: 4px; padding: 4px 6px; font: inherit; font-size: 0.78rem; min-width: 0; }
      .row .val { font-size: 0.7rem; color: var(--ink-muted); min-width: 40px; text-align: right; }

      button {
        padding: 0.45rem 0.7rem; background: #0f0d08; color: var(--ink);
        border: 1px solid var(--hairline); border-radius: 4px;
        font: inherit; font-size: 0.76rem; cursor: pointer; transition: background 0.12s, border-color 0.12s;
      }
      button:hover:not(:disabled) { background: #1a160e; border-color: var(--ink-muted); }
      button:disabled { opacity: 0.5; cursor: not-allowed; }
      button.primary { background: var(--accent); color: #fff; border-color: var(--accent); font-weight: 600; }
      button.primary:hover:not(:disabled) { background: #ff7070; border-color: #ff7070; }
      button.icon { padding: 0.35rem 0.55rem; font-size: 0.9rem; line-height: 1; }
      button.danger:hover:not(:disabled) { background: #3a1a1a; border-color: var(--accent); color: var(--accent); }
      button.block { width: 100%; }

      .status { font-size: 0.76rem; color: var(--ink-muted); margin-top: 0.5rem; min-height: 1.2em; word-break: break-all; }
      .status.ok { color: var(--accent-2); }
      .status.err { color: var(--accent); }

      main { flex: 1; padding: 1rem 1.1rem 2rem; overflow: auto; display: flex; flex-direction: column; gap: 0.7rem; }
      .canvas-wrap {
        position: relative; background:
          conic-gradient(#0b0906 25%, #0f0d08 0 50%, #0b0906 0 75%, #0f0d08 0) 0 0 / 32px 32px;
        border: 1px solid var(--hairline); border-radius: 4px; overflow: hidden; user-select: none;
        display: flex; align-items: center; justify-content: center;
      }
      canvas { display: block; max-width: 100%; height: auto; touch-action: none; cursor: grab; }
      canvas.dragging { cursor: grabbing; }
      .hint { font-size: 0.76rem; color: var(--ink-muted); }
      .hint kbd { background: #0f0d08; border: 1px solid var(--hairline); border-bottom-width: 2px; border-radius: 3px; padding: 1px 5px; font: inherit; font-size: 0.72rem; }

      /* Layer list */
      .layers { display: flex; flex-direction: column; gap: 0.5rem; }
      .layer {
        background: var(--panel-2); border: 1px solid var(--hairline); border-radius: 5px;
        padding: 0.55rem 0.6rem;
      }
      .layer.selected { border-color: var(--accent); box-shadow: 0 0 0 1px var(--accent) inset; }
      .layer-head { display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.35rem; }
      .layer-thumb { width: 32px; height: 32px; border: 1px solid var(--hairline); background: #0b0906; object-fit: cover; flex: 0 0 32px; }
      .layer-name { flex: 1; font-size: 0.78rem; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .layer-actions { display: flex; gap: 0.2rem; }
      .layer-body { display: none; padding-top: 0.25rem; border-top: 1px dashed var(--hairline); margin-top: 0.25rem; }
      .layer.expanded .layer-body { display: block; }

      .drop-zone {
        padding: 0.8rem; border: 1.5px dashed var(--hairline); border-radius: 5px;
        text-align: center; font-size: 0.78rem; color: var(--ink-muted);
        cursor: pointer; transition: background 0.12s, border-color 0.12s;
      }
      .drop-zone:hover, .drop-zone.over { border-color: var(--accent); color: var(--ink); background: #1a160e; }
      .drop-zone input[type="file"] { display: none; }

      .gallery {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.35rem;
        max-height: 260px; overflow-y: auto; padding: 0.3rem; background: #0f0d08; border: 1px solid var(--hairline); border-radius: 4px;
      }
      .gallery .g-item {
        position: relative; width: 100%; aspect-ratio: 1 / 1; overflow: hidden;
        background: #0b0906; border: 1px solid var(--hairline); border-radius: 3px; cursor: pointer;
      }
      .gallery .g-item img { width: 100%; height: 100%; object-fit: cover; }
      .gallery .g-item:hover { border-color: var(--accent); }

      details > summary { cursor: pointer; font-size: 0.78rem; padding: 0.3rem 0; color: var(--ink-muted); }
      details[open] > summary { color: var(--ink); }
    </style>
  </head>
  <body>
    <aside class="sidebar">
      <h1>Hero composer</h1>
      <div class="sub">Stack N image layers, drag to place, save to <code>public/media/&lt;dir&gt;/&lt;file&gt;</code>.</div>

      <div class="group">
        <div class="group-label">Canvas</div>
        <div class="row">
          <label for="canvas-w">Size</label>
          <input id="canvas-w" type="number" value="1600" min="200" max="4096" step="10" />
          <span class="val">×</span>
          <input id="canvas-h" type="number" value="800" min="200" max="4096" step="10" />
        </div>
        <div class="row">
          <label for="bg-fill">Fill</label>
          <input id="bg-fill" type="color" value="#141414" />
          <span class="val">below all layers</span>
        </div>
      </div>

      <div class="group">
        <div class="group-label">Add layer</div>
        <label class="drop-zone" id="drop">
          <input type="file" id="file-input" accept="image/*" multiple />
          <div><strong>Upload images</strong> (drop or click)</div>
          <div style="font-size: 0.72rem; margin-top: 0.2rem;">Added as in-memory layers. Use <em>Persist uploads</em> below to save to disk.</div>
        </label>

        <div class="row" style="margin-top: 0.55rem;">
          <label for="persist-uploads" style="flex: 1;">Persist uploads</label>
          <input id="persist-uploads" type="checkbox" />
          <span class="val">→ /media/uploads/</span>
        </div>

        <details style="margin-top: 0.45rem;">
          <summary>Pick from project gallery</summary>
          <div class="gallery" id="gallery"></div>
        </details>
      </div>

      <div class="group">
        <div class="group-label">Layers <span id="layer-count" style="color: var(--ink-muted); font-weight: normal;"></span></div>
        <div class="layers" id="layers"></div>
      </div>

      <div class="group">
        <div class="group-label">Save</div>
        <div class="row">
          <label for="save-dir">Dir</label>
          <input id="save-dir" type="text" value="posts/kiddycody" placeholder="posts/&lt;slug&gt;" />
        </div>
        <div class="row">
          <label for="save-filename">File</label>
          <input id="save-filename" type="text" value="hero-logo-terrain.png" placeholder="name.png" />
        </div>
        <div class="row" style="gap: 0.35rem;">
          <button class="primary block" id="save-btn" style="flex: 2;">Save</button>
          <button class="block" id="download-btn" style="flex: 1;">Download</button>
        </div>
        <div class="status" id="status">Ready.</div>
        <div style="font-size: 0.7rem; color: var(--ink-muted); margin-top: 0.3rem;">Writes to <code>public/media/&lt;dir&gt;/&lt;file&gt;</code>. Only works under <code>pnpm dev</code>.</div>
      </div>
    </aside>

    <main>
      <div class="hint">Click a layer to select. <kbd>Drag</kbd> on canvas to move selected layer. <kbd>Shift</kbd> + drag = 1% snap.</div>
      <div class="canvas-wrap">
        <canvas id="composer" width="1600" height="800"></canvas>
      </div>
    </main>

    <!-- Layer template used for each row in the sidebar list -->
    <template id="layer-tpl">
      <div class="layer" data-layer>
        <div class="layer-head">
          <img class="layer-thumb" data-thumb alt="" />
          <div class="layer-name" data-name></div>
          <div class="layer-actions">
            <button class="icon" data-toggle title="Toggle visibility">●</button>
            <button class="icon" data-up title="Move up">↑</button>
            <button class="icon" data-down title="Move down">↓</button>
            <button class="icon" data-dup title="Duplicate">⧉</button>
            <button class="icon danger" data-del title="Delete">✕</button>
          </div>
        </div>
        <div class="layer-body">
          <div class="row">
            <label>Mode</label>
            <select data-mode>
              <option value="cover">cover canvas</option>
              <option value="contain">contain canvas</option>
              <option value="placed" selected>placed</option>
            </select>
          </div>
          <div class="row" data-placed-only>
            <label>Width</label>
            <input type="range" data-w min="20" max="4096" step="2" />
            <span class="val" data-w-val></span>
          </div>
          <div class="row" data-placed-only>
            <label>X</label>
            <input type="range" data-x min="-20" max="120" step="0.1" />
            <span class="val" data-x-val></span>
          </div>
          <div class="row" data-placed-only>
            <label>Y</label>
            <input type="range" data-y min="-20" max="120" step="0.1" />
            <span class="val" data-y-val></span>
          </div>
          <div class="row">
            <label>Opacity</label>
            <input type="range" data-op min="0" max="1" step="0.01" value="1" />
            <span class="val" data-op-val>1</span>
          </div>

          <details>
            <summary>Paper panel behind layer</summary>
            <div class="row">
              <label>Enabled</label>
              <input type="checkbox" data-panel-on />
            </div>
            <div class="row">
              <label>Padding</label>
              <input type="range" data-panel-pad min="0" max="200" step="1" value="24" />
              <span class="val" data-panel-pad-val>24</span>
            </div>
            <div class="row">
              <label>Fill</label>
              <input type="color" data-panel-fill value="#f4ecdc" />
            </div>
            <div class="row">
              <label>Border</label>
              <input type="color" data-panel-border value="#1a1208" />
              <input type="number" data-panel-border-w min="0" max="10" step="0.5" value="1.5" style="width: 56px;" />
            </div>
            <div class="row">
              <label>Shadow</label>
              <input type="checkbox" data-panel-shadow checked />
            </div>
            <div class="row">
              <label>Radius</label>
              <input type="range" data-panel-radius min="0" max="60" step="1" value="0" />
              <span class="val" data-panel-radius-val>0</span>
            </div>
          </details>
        </div>
      </div>
    </template>

    <script is:inline>
    (() => {
      const $ = (id) => document.getElementById(id);
      const canvas = $('composer');
      const ctx = canvas.getContext('2d');

      /** Global composer state */
      const state = {
        W: 1600,
        H: 800,
        bgFill: '#141414',
        layers: [],          // array of Layer objects, bottom-to-top
        selectedId: null,
      };

      /** Layer shape:
       * {
       *   id: string, name: string, src: string, img: HTMLImageElement | null,
       *   visible: true, mode: 'cover'|'contain'|'placed',
       *   x: 50, y: 50, w: 600, opacity: 1,
       *   panel: { on, pad, fill, border, borderW, shadow, radius }
       * }
       */

      let nextId = 1;
      function mkId() { return 'l' + (nextId++); }

      function makeLayer({ src, name, mode }) {
        return {
          id: mkId(), name: name || src.split('/').pop(), src, img: null,
          visible: true, mode: mode || 'placed',
          x: 50, y: 50, w: 600, opacity: 1,
          panel: { on: false, pad: 24, fill: '#f4ecdc', border: '#1a1208', borderW: 1.5, shadow: true, radius: 0 },
        };
      }

      function loadImage(src) {
        return new Promise((res, rej) => {
          const img = new Image();
          img.crossOrigin = 'anonymous';
          img.onload = () => res(img);
          img.onerror = rej;
          img.src = src;
        });
      }

      async function addLayer(init) {
        const L = makeLayer(init);
        state.layers.push(L);
        try { L.img = await loadImage(L.src); } catch {}
        if (L.mode === 'placed' && L.img) {
          // sensible default width: 40% of canvas
          L.w = Math.round(state.W * 0.4);
        }
        state.selectedId = L.id;
        renderAll();
      }

      function removeLayer(id) {
        const i = state.layers.findIndex(l => l.id === id);
        if (i >= 0) state.layers.splice(i, 1);
        if (state.selectedId === id) state.selectedId = null;
        renderAll();
      }
      function moveLayer(id, delta) {
        const i = state.layers.findIndex(l => l.id === id);
        const j = i + delta;
        if (i < 0 || j < 0 || j >= state.layers.length) return;
        const tmp = state.layers[i]; state.layers[i] = state.layers[j]; state.layers[j] = tmp;
        renderAll();
      }
      function duplicateLayer(id) {
        const L = state.layers.find(l => l.id === id);
        if (!L) return;
        const clone = JSON.parse(JSON.stringify({ ...L, img: null }));
        clone.id = mkId();
        clone.img = L.img;
        state.layers.push(clone);
        state.selectedId = clone.id;
        renderAll();
      }

      // ---------- Canvas drawing ----------
      function drawCover(img, dx, dy, dw, dh) {
        const ir = img.naturalWidth / img.naturalHeight;
        const br = dw / dh;
        let sx, sy, sw, sh;
        if (ir > br) { sh = img.naturalHeight; sw = sh * br; sx = (img.naturalWidth - sw) / 2; sy = 0; }
        else { sw = img.naturalWidth; sh = sw / br; sx = 0; sy = (img.naturalHeight - sh) / 2; }
        ctx.drawImage(img, sx, sy, sw, sh, dx, dy, dw, dh);
      }
      function drawContain(img, dx, dy, dw, dh) {
        const ir = img.naturalWidth / img.naturalHeight;
        const br = dw / dh;
        let rw, rh;
        if (ir > br) { rw = dw; rh = dw / ir; } else { rh = dh; rw = dh * ir; }
        ctx.drawImage(img, dx + (dw - rw) / 2, dy + (dh - rh) / 2, rw, rh);
      }
      function roundRectPath(x, y, w, h, r) {
        const rr = Math.max(0, Math.min(r, Math.min(w, h) / 2));
        ctx.beginPath();
        ctx.moveTo(x + rr, y);
        ctx.lineTo(x + w - rr, y); ctx.quadraticCurveTo(x + w, y, x + w, y + rr);
        ctx.lineTo(x + w, y + h - rr); ctx.quadraticCurveTo(x + w, y + h, x + w - rr, y + h);
        ctx.lineTo(x + rr, y + h); ctx.quadraticCurveTo(x, y + h, x, y + h - rr);
        ctx.lineTo(x, y + rr); ctx.quadraticCurveTo(x, y, x + rr, y);
        ctx.closePath();
      }

      /** Compute the bounding box of a placed layer (includes panel padding). */
      function layerBox(L) {
        if (!L.img) return null;
        if (L.mode !== 'placed') return { x: 0, y: 0, w: state.W, h: state.H, placed: false };
        const w = L.w;
        const h = Math.round(w * (L.img.naturalHeight / L.img.naturalWidth));
        const pad = L.panel.on ? L.panel.pad : 0;
        const boxW = w + pad * 2, boxH = h + pad * 2;
        const cx = (L.x / 100) * state.W;
        const cy = (L.y / 100) * state.H;
        return { x: Math.round(cx - boxW / 2), y: Math.round(cy - boxH / 2), w: boxW, h: boxH, placed: true, imgW: w, imgH: h, pad };
      }

      function drawCanvas() {
        canvas.width = state.W;
        canvas.height = state.H;
        ctx.fillStyle = state.bgFill;
        ctx.fillRect(0, 0, state.W, state.H);

        for (const L of state.layers) {
          if (!L.visible || !L.img) continue;
          ctx.save();
          ctx.globalAlpha = L.opacity;

          const box = layerBox(L);
          if (L.mode === 'cover') {
            drawCover(L.img, 0, 0, state.W, state.H);
          } else if (L.mode === 'contain') {
            drawContain(L.img, 0, 0, state.W, state.H);
          } else if (box) {
            if (L.panel.on) {
              if (L.panel.shadow) {
                ctx.save();
                ctx.fillStyle = 'rgba(26,18,8,0.35)';
                roundRectPath(box.x + 3, box.y + 3, box.w, box.h, L.panel.radius);
                ctx.fill();
                ctx.restore();
              }
              ctx.fillStyle = L.panel.fill;
              roundRectPath(box.x, box.y, box.w, box.h, L.panel.radius);
              ctx.fill();
              if (L.panel.borderW > 0) {
                ctx.lineWidth = L.panel.borderW;
                ctx.strokeStyle = L.panel.border;
                roundRectPath(box.x, box.y, box.w, box.h, L.panel.radius);
                ctx.stroke();
              }
            }
            ctx.drawImage(L.img, box.x + box.pad, box.y + box.pad, box.imgW, box.imgH);
          }
          ctx.restore();
        }
      }

      // ---------- Sidebar rendering ----------
      const layersEl = $('layers');
      const layerCountEl = $('layer-count');
      const tpl = $('layer-tpl');

      function renderLayers() {
        layersEl.innerHTML = '';
        layerCountEl.textContent = state.layers.length ? '(' + state.layers.length + ')' : '';
        // Render top-down (last drawn = top of list)
        [...state.layers].reverse().forEach((L) => {
          const node = tpl.content.firstElementChild.cloneNode(true);
          node.dataset.id = L.id;
          if (L.id === state.selectedId) node.classList.add('selected', 'expanded');

          const name = node.querySelector('[data-name]');
          name.textContent = L.name;
          const thumb = node.querySelector('[data-thumb]');
          thumb.src = L.src;

          const tog = node.querySelector('[data-toggle]');
          tog.textContent = L.visible ? '●' : '○';
          tog.title = L.visible ? 'Hide' : 'Show';

          node.querySelector('[data-up]').addEventListener('click', (e) => { e.stopPropagation(); moveLayer(L.id, 1); });
          node.querySelector('[data-down]').addEventListener('click', (e) => { e.stopPropagation(); moveLayer(L.id, -1); });
          node.querySelector('[data-dup]').addEventListener('click', (e) => { e.stopPropagation(); duplicateLayer(L.id); });
          node.querySelector('[data-del]').addEventListener('click', (e) => { e.stopPropagation(); removeLayer(L.id); });
          tog.addEventListener('click', (e) => { e.stopPropagation(); L.visible = !L.visible; renderAll(); });

          node.addEventListener('click', () => {
            state.selectedId = (state.selectedId === L.id ? null : L.id);
            renderAll();
          });

          // Per-layer controls
          const modeEl = node.querySelector('[data-mode]');
          modeEl.value = L.mode;
          modeEl.addEventListener('change', (e) => { e.stopPropagation(); L.mode = modeEl.value; updatePlacedVisibility(node, L); renderAll(); });

          function bindRange(sel, key, valSel) {
            const el = node.querySelector(sel);
            const valEl = valSel ? node.querySelector(valSel) : null;
            el.value = String(key === 'w' ? L.w : key === 'x' ? L.x : key === 'y' ? L.y : key === 'op' ? L.opacity : 0);
            if (valEl) valEl.textContent = el.value;
            const upd = (ev) => {
              ev && ev.stopPropagation();
              const v = parseFloat(el.value);
              if (key === 'w') L.w = v;
              else if (key === 'x') L.x = v;
              else if (key === 'y') L.y = v;
              else if (key === 'op') L.opacity = v;
              if (valEl) valEl.textContent = String(v);
              drawCanvas();
            };
            el.addEventListener('input', upd);
          }
          bindRange('[data-w]', 'w', '[data-w-val]');
          bindRange('[data-x]', 'x', '[data-x-val]');
          bindRange('[data-y]', 'y', '[data-y-val]');
          bindRange('[data-op]', 'op', '[data-op-val]');

          // Panel controls
          const pOn = node.querySelector('[data-panel-on]'); pOn.checked = L.panel.on;
          pOn.addEventListener('change', (e) => { e.stopPropagation(); L.panel.on = pOn.checked; drawCanvas(); });
          const pPad = node.querySelector('[data-panel-pad]'); pPad.value = L.panel.pad;
          const pPadVal = node.querySelector('[data-panel-pad-val]'); pPadVal.textContent = L.panel.pad;
          pPad.addEventListener('input', (e) => { e.stopPropagation(); L.panel.pad = parseFloat(pPad.value); pPadVal.textContent = pPad.value; drawCanvas(); });
          const pFill = node.querySelector('[data-panel-fill]'); pFill.value = L.panel.fill;
          pFill.addEventListener('input', (e) => { e.stopPropagation(); L.panel.fill = pFill.value; drawCanvas(); });
          const pBorder = node.querySelector('[data-panel-border]'); pBorder.value = L.panel.border;
          pBorder.addEventListener('input', (e) => { e.stopPropagation(); L.panel.border = pBorder.value; drawCanvas(); });
          const pBorderW = node.querySelector('[data-panel-border-w]'); pBorderW.value = L.panel.borderW;
          pBorderW.addEventListener('input', (e) => { e.stopPropagation(); L.panel.borderW = parseFloat(pBorderW.value) || 0; drawCanvas(); });
          const pShadow = node.querySelector('[data-panel-shadow]'); pShadow.checked = L.panel.shadow;
          pShadow.addEventListener('change', (e) => { e.stopPropagation(); L.panel.shadow = pShadow.checked; drawCanvas(); });
          const pR = node.querySelector('[data-panel-radius]'); pR.value = L.panel.radius;
          const pRVal = node.querySelector('[data-panel-radius-val]'); pRVal.textContent = L.panel.radius;
          pR.addEventListener('input', (e) => { e.stopPropagation(); L.panel.radius = parseFloat(pR.value); pRVal.textContent = pR.value; drawCanvas(); });

          // Widen range for layer width based on canvas
          const wEl = node.querySelector('[data-w]');
          wEl.max = String(Math.max(state.W, state.H) * 1.5 | 0);

          updatePlacedVisibility(node, L);
          layersEl.appendChild(node);
        });
      }

      function updatePlacedVisibility(node, L) {
        const rows = node.querySelectorAll('[data-placed-only]');
        rows.forEach((r) => r.style.display = L.mode === 'placed' ? '' : 'none');
      }

      function renderAll() { renderLayers(); drawCanvas(); }

      // ---------- Global controls ----------
      const wEl = $('canvas-w'), hEl = $('canvas-h');
      const updateCanvasSize = () => {
        state.W = parseInt(wEl.value) || 1600;
        state.H = parseInt(hEl.value) || 800;
        renderAll();
      };
      wEl.addEventListener('input', updateCanvasSize);
      hEl.addEventListener('input', updateCanvasSize);
      $('bg-fill').addEventListener('input', (e) => { state.bgFill = e.target.value; drawCanvas(); });

      // ---------- File upload / drag-drop ----------
      const drop = $('drop');
      const fileInput = $('file-input');
      const persistCheckbox = $('persist-uploads');

      async function handleFiles(fileList) {
        for (const file of Array.from(fileList)) {
          if (!file.type.startsWith('image/')) continue;
          let src;
          if (persistCheckbox.checked) {
            // Upload to /media/uploads/ so the src survives reloads
            const safe = file.name.replace(/[^A-Za-z0-9._-]/g, '_');
            const filename = Date.now() + '-' + safe;
            try {
              const res = await fetch('/api/upload-media?dir=uploads&filename=' + encodeURIComponent(filename), {
                method: 'POST',
                headers: { 'content-type': file.type },
                body: file,
              });
              if (!res.ok) throw new Error(await res.text());
              const data = await res.json();
              src = data.path;
              setStatus('Uploaded ' + data.path, 'ok');
            } catch (e) {
              // Fall back to data URL if dev server isn't running
              src = await fileToDataURL(file);
              setStatus('Upload failed, using in-memory data URL: ' + (e && e.message ? e.message : e), 'err');
            }
          } else {
            src = await fileToDataURL(file);
          }
          await addLayer({ src, name: file.name });
        }
      }
      function fileToDataURL(file) {
        return new Promise((res, rej) => {
          const r = new FileReader();
          r.onload = () => res(r.result);
          r.onerror = rej;
          r.readAsDataURL(file);
        });
      }

      drop.addEventListener('click', () => fileInput.click());
      fileInput.addEventListener('change', () => { if (fileInput.files) handleFiles(fileInput.files); fileInput.value = ''; });
      ;['dragenter', 'dragover'].forEach((ev) => {
        drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.add('over'); });
      });
      ;['dragleave', 'drop'].forEach((ev) => {
        drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.remove('over'); });
      });
      drop.addEventListener('drop', (e) => { if (e.dataTransfer && e.dataTransfer.files) handleFiles(e.dataTransfer.files); });

      // ---------- Gallery ----------
      const galleryEl = $('gallery');
      async function loadGallery() {
        try {
          const res = await fetch('/api/list-media');
          if (!res.ok) throw new Error('status ' + res.status);
          const data = await res.json();
          galleryEl.innerHTML = '';
          data.items
            .sort((a, b) => a.path.localeCompare(b.path))
            .forEach((it) => {
              const div = document.createElement('div');
              div.className = 'g-item';
              div.title = it.path;
              const img = document.createElement('img');
              img.loading = 'lazy';
              img.src = it.path;
              div.appendChild(img);
              div.addEventListener('click', () => addLayer({ src: it.path, name: it.path.split('/').pop() }));
              galleryEl.appendChild(div);
            });
        } catch (e) {
          galleryEl.innerHTML = '<div style="font-size: 0.76rem; color: var(--ink-muted); padding: 0.4rem;">Gallery unavailable (only works in <code>pnpm dev</code>).</div>';
        }
      }

      // ---------- Canvas drag-to-move (affects selected placed layer) ----------
      let drag = null;
      function canvasCoords(ev) {
        const rect = canvas.getBoundingClientRect();
        const sx = state.W / rect.width, sy = state.H / rect.height;
        const p = ev.touches ? ev.touches[0] : ev;
        return { x: (p.clientX - rect.left) * sx, y: (p.clientY - rect.top) * sy };
      }
      function selectedLayer() {
        return state.layers.find(l => l.id === state.selectedId) || null;
      }
      // Click-to-select: pick the topmost placed layer whose box contains the point.
      canvas.addEventListener('pointerdown', (ev) => {
        const { x, y } = canvasCoords(ev);
        for (let i = state.layers.length - 1; i >= 0; i--) {
          const L = state.layers[i];
          if (!L.visible || L.mode !== 'placed') continue;
          const box = layerBox(L);
          if (box && x >= box.x && x <= box.x + box.w && y >= box.y && y <= box.y + box.h) {
            state.selectedId = L.id;
            drag = { id: L.id, offX: x - (box.x + box.w / 2), offY: y - (box.y + box.h / 2) };
            canvas.classList.add('dragging');
            canvas.setPointerCapture(ev.pointerId);
            renderLayers();
            drawCanvas();
            ev.preventDefault();
            return;
          }
        }
        // Nothing hit; clear selection
        if (state.selectedId) { state.selectedId = null; renderLayers(); drawCanvas(); }
      });
      canvas.addEventListener('pointermove', (ev) => {
        if (!drag) return;
        const L = state.layers.find(l => l.id === drag.id);
        if (!L) return;
        const { x, y } = canvasCoords(ev);
        let nx = ((x - drag.offX) / state.W) * 100;
        let ny = ((y - drag.offY) / state.H) * 100;
        if (ev.shiftKey) { nx = Math.round(nx); ny = Math.round(ny); }
        nx = Math.max(-20, Math.min(120, nx));
        ny = Math.max(-20, Math.min(120, ny));
        L.x = nx; L.y = ny;
        drawCanvas();
        // update the sidebar sliders for the selected layer without rebuilding DOM
        const node = layersEl.querySelector('[data-id="' + L.id + '"]');
        if (node) {
          const xEl = node.querySelector('[data-x]'); if (xEl) xEl.value = nx.toFixed(1);
          const yEl = node.querySelector('[data-y]'); if (yEl) yEl.value = ny.toFixed(1);
          const xv = node.querySelector('[data-x-val]'); if (xv) xv.textContent = nx.toFixed(1);
          const yv = node.querySelector('[data-y-val]'); if (yv) yv.textContent = ny.toFixed(1);
        }
      });
      canvas.addEventListener('pointerup', () => { drag = null; canvas.classList.remove('dragging'); });
      canvas.addEventListener('pointercancel', () => { drag = null; canvas.classList.remove('dragging'); });

      // ---------- Save / Download ----------
      const statusEl = $('status');
      function setStatus(t, cls) { statusEl.className = 'status' + (cls ? ' ' + cls : ''); statusEl.textContent = t; }
      function toBlob() {
        return new Promise((res) => canvas.toBlob((b) => res(b), 'image/png'));
      }
      $('save-btn').addEventListener('click', async () => {
        const btn = $('save-btn');
        btn.disabled = true;
        setStatus('Saving...');
        try {
          const blob = await toBlob();
          const dir = $('save-dir').value.trim();
          const file = $('save-filename').value.trim();
          const qs = new URLSearchParams();
          if (dir) qs.set('dir', dir);
          qs.set('filename', file);
          const res = await fetch('/api/save-media?' + qs.toString(), {
            method: 'POST',
            headers: { 'content-type': 'image/png' },
            body: blob,
          });
          if (!res.ok) throw new Error((await res.text()) || 'HTTP ' + res.status);
          const data = await res.json();
          setStatus('Saved ' + (data.bytes / 1024).toFixed(1) + ' KB → ' + data.path, 'ok');
        } catch (e) {
          setStatus('Save failed: ' + (e && e.message ? e.message : e) + ' (only works under `pnpm dev`)', 'err');
        } finally {
          btn.disabled = false;
        }
      });
      $('download-btn').addEventListener('click', async () => {
        const blob = await toBlob();
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url; a.download = $('save-filename').value || 'composition.png';
        document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
      });

      // ---------- Init ----------
      (async function init() {
        // Seed with the current KiddyCody hero so it opens on a useful scene.
        await addLayer({ src: '/media/posts/kiddycody/voxel-engine-cli.png', name: 'voxel-engine-cli.png', mode: 'cover' });
        await addLayer({ src: '/media/posts/kiddycody/kiddycody-final-logo.png', name: 'kiddycody-final-logo.png', mode: 'placed' });
        const logo = state.layers[1];
        if (logo) { logo.x = 16; logo.y = 76; logo.w = Math.round(state.W * 0.26); logo.panel.on = true; }
        loadGallery();
        renderAll();
      })();
    })();
    </script>
  </body>
</html>
