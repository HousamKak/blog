---
// Dev-only tool. Lives outside the main nav. Drag the logo panel around
// a live 1600x800 canvas, tune size / padding / colors, then save straight
// to public/media/posts/kiddycody/hero-logo-terrain.png via the POST route.
// When built statically, this page still ships (it's an .astro page), but
// the "Save" button relies on /api/save-kiddycody-hero which only works
// under `pnpm dev`.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>KiddyCody hero composer</title>
    <style>
      :root {
        --bg: #14110c;
        --panel: #1f1b14;
        --ink: #e8dec5;
        --ink-muted: #968a6e;
        --accent: #e36363;
        --hairline: #3a3325;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; background: var(--bg); color: var(--ink); font-family: ui-sans-serif, system-ui, -apple-system, sans-serif; }
      body { min-height: 100dvh; display: flex; }

      .sidebar {
        width: 320px; min-width: 320px; padding: 1.25rem 1.25rem 2rem;
        background: var(--panel); border-right: 1px solid var(--hairline);
        overflow-y: auto; height: 100dvh;
      }
      .sidebar h1 { font-size: 1.05rem; margin: 0 0 0.25rem; letter-spacing: 0.02em; }
      .sidebar .sub { font-size: 0.78rem; color: var(--ink-muted); margin-bottom: 1.25rem; }
      .group { margin-bottom: 1.1rem; padding-bottom: 1rem; border-bottom: 1px dashed var(--hairline); }
      .group:last-child { border-bottom: none; }
      .group-label { font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 0.5rem; }

      .row { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.45rem; }
      .row label { flex: 0 0 110px; font-size: 0.78rem; color: var(--ink); }
      .row input[type="range"] { flex: 1; }
      .row input[type="number"] { width: 72px; background: #0f0d08; color: var(--ink); border: 1px solid var(--hairline); border-radius: 4px; padding: 4px 6px; font: inherit; font-size: 0.78rem; }
      .row input[type="color"] { width: 44px; height: 26px; padding: 0; border: 1px solid var(--hairline); background: transparent; cursor: pointer; }
      .row input[type="checkbox"] { accent-color: var(--accent); transform: scale(1.1); }
      .row select { flex: 1; background: #0f0d08; color: var(--ink); border: 1px solid var(--hairline); border-radius: 4px; padding: 4px 6px; font: inherit; font-size: 0.78rem; }
      .row .val { font-size: 0.72rem; color: var(--ink-muted); min-width: 44px; text-align: right; }

      button.save {
        width: 100%; padding: 0.75rem 1rem; margin-top: 0.5rem;
        background: var(--accent); color: #fff; border: none; border-radius: 6px;
        font: inherit; font-weight: 600; font-size: 0.9rem; letter-spacing: 0.02em;
        cursor: pointer; transition: background 0.15s;
      }
      button.save:hover { background: #ff7070; }
      button.save:disabled { background: #5a3232; cursor: not-allowed; }
      button.secondary {
        width: 100%; padding: 0.55rem 1rem; margin-top: 0.4rem;
        background: transparent; color: var(--ink); border: 1px solid var(--hairline); border-radius: 6px;
        font: inherit; font-size: 0.78rem; cursor: pointer;
      }
      button.secondary:hover { background: #272115; }

      .status { font-size: 0.78rem; color: var(--ink-muted); margin-top: 0.5rem; min-height: 1.2em; }
      .status.ok { color: #78c07a; }
      .status.err { color: var(--accent); }

      main { flex: 1; padding: 1.25rem; overflow: auto; display: flex; flex-direction: column; gap: 0.75rem; }
      .canvas-wrap {
        position: relative; background: #0b0906; border: 1px solid var(--hairline);
        border-radius: 6px; overflow: hidden; user-select: none;
        display: flex; align-items: center; justify-content: center;
      }
      canvas { display: block; max-width: 100%; height: auto; touch-action: none; cursor: grab; }
      canvas.dragging { cursor: grabbing; }
      .hint { font-size: 0.78rem; color: var(--ink-muted); }
      .hint kbd { background: #0f0d08; border: 1px solid var(--hairline); border-bottom-width: 2px; border-radius: 3px; padding: 1px 5px; font: inherit; font-size: 0.72rem; }
    </style>
  </head>
  <body>
    <aside class="sidebar">
      <h1>KiddyCody hero composer</h1>
      <div class="sub">Dev-only. Drag the logo on the canvas. Save to <code>hero-logo-terrain.png</code>.</div>

      <div class="group">
        <div class="group-label">Sources</div>
        <div class="row">
          <label for="bg-src">Backdrop</label>
          <select id="bg-src">
            <option value="/media/posts/kiddycody/voxel-engine-cli.png" selected>Voxel engine (~36k blocks)</option>
            <option value="/media/posts/kiddycody/engine-manual-placement.png">Engine, manual placement</option>
            <option value="/media/posts/kiddycody/canvas-branched-variants.png">Canvas, branched variants</option>
            <option value="/media/posts/kiddycody/brand-system-sheet.png">Brand system sheet</option>
          </select>
        </div>
        <div class="row">
          <label for="logo-src">Logo</label>
          <select id="logo-src">
            <option value="/media/posts/kiddycody/kiddycody-final-logo.png" selected>KiddyCody (final)</option>
            <option value="/media/posts/kiddycody/svg-variant-k.png">K variant</option>
            <option value="/media/posts/kiddycody/svg-refactor-brand-panel.png">SVG refactor (brand panel)</option>
          </select>
        </div>
      </div>

      <div class="group">
        <div class="group-label">Canvas</div>
        <div class="row">
          <label for="canvas-w">Width</label>
          <input id="canvas-w" type="number" value="1600" min="400" max="3000" step="10" />
          <label for="canvas-h" style="flex:0 0 auto;">H</label>
          <input id="canvas-h" type="number" value="800" min="200" max="2000" step="10" />
        </div>
        <div class="row">
          <label for="fit-mode">Fit</label>
          <select id="fit-mode">
            <option value="cover" selected>cover (crop)</option>
            <option value="contain">contain (letterbox)</option>
          </select>
        </div>
        <div class="row">
          <label for="bg-fill">Letterbox fill</label>
          <input id="bg-fill" type="color" value="#14110c" />
        </div>
      </div>

      <div class="group">
        <div class="group-label">Logo</div>
        <div class="row">
          <label for="logo-w">Width (px)</label>
          <input id="logo-w" type="range" min="80" max="1200" step="4" value="460" />
          <span class="val" id="logo-w-val">460</span>
        </div>
        <div class="row">
          <label for="logo-x">X</label>
          <input id="logo-x" type="range" min="0" max="100" step="0.1" value="12" />
          <span class="val" id="logo-x-val">12</span>
        </div>
        <div class="row">
          <label for="logo-y">Y</label>
          <input id="logo-y" type="range" min="0" max="100" step="0.1" value="72" />
          <span class="val" id="logo-y-val">72</span>
        </div>
      </div>

      <div class="group">
        <div class="group-label">Panel behind logo</div>
        <div class="row">
          <label for="panel-on">Show panel</label>
          <input id="panel-on" type="checkbox" checked />
        </div>
        <div class="row">
          <label for="panel-pad">Padding</label>
          <input id="panel-pad" type="range" min="0" max="120" step="1" value="30" />
          <span class="val" id="panel-pad-val">30</span>
        </div>
        <div class="row">
          <label for="panel-bg">Fill</label>
          <input id="panel-bg" type="color" value="#f4ecdc" />
        </div>
        <div class="row">
          <label for="panel-border">Border</label>
          <input id="panel-border" type="color" value="#1a1208" />
        </div>
        <div class="row">
          <label for="panel-border-w">Border px</label>
          <input id="panel-border-w" type="range" min="0" max="8" step="0.5" value="1.5" />
          <span class="val" id="panel-border-w-val">1.5</span>
        </div>
        <div class="row">
          <label for="panel-shadow">Offset shadow</label>
          <input id="panel-shadow" type="checkbox" checked />
        </div>
        <div class="row">
          <label for="panel-round">Corner radius</label>
          <input id="panel-round" type="range" min="0" max="40" step="1" value="0" />
          <span class="val" id="panel-round-val">0</span>
        </div>
      </div>

      <div class="group">
        <div class="group-label">Save</div>
        <div class="row">
          <label for="save-filename">Filename</label>
          <select id="save-filename">
            <option value="hero-logo-terrain.png" selected>hero-logo-terrain.png</option>
            <option value="hero-logo-terrain-alt.png">hero-logo-terrain-alt.png</option>
          </select>
        </div>
        <button class="save" id="save-btn">Save as thumbnail</button>
        <button class="secondary" id="download-btn">Download PNG</button>
        <div class="status" id="status">Ready.</div>
      </div>
    </aside>

    <main>
      <div class="hint">Drag the logo on the canvas. Hold <kbd>Shift</kbd> while dragging to snap to 1% grid.</div>
      <div class="canvas-wrap">
        <canvas id="composer" width="1600" height="800"></canvas>
      </div>
    </main>

    <script is:inline>
      (() => {
        const $ = (id) => document.getElementById(id);
        const canvas = $('composer');
        const ctx = canvas.getContext('2d');

        const state = {
          bgSrc: $('bg-src').value,
          logoSrc: $('logo-src').value,
          W: 1600, H: 800,
          fit: 'cover',
          bgFill: '#14110c',
          logoW: 460,
          logoX: 12,   // percent of canvas width (logo center-x anchor)
          logoY: 72,   // percent of canvas height
          panel: true,
          panelPad: 30,
          panelBg: '#f4ecdc',
          panelBorder: '#1a1208',
          panelBorderW: 1.5,
          panelShadow: true,
          panelRound: 0,
        };

        const images = { bg: null, logo: null };

        function load(src) {
          return new Promise((res, rej) => {
            const img = new Image();
            img.crossOrigin = 'anonymous';
            img.onload = () => res(img);
            img.onerror = (e) => rej(e);
            img.src = src;
          });
        }

        async function loadBg() {
          images.bg = null;
          render();
          try { images.bg = await load(state.bgSrc); } catch {}
          render();
        }
        async function loadLogo() {
          images.logo = null;
          render();
          try { images.logo = await load(state.logoSrc); } catch {}
          render();
        }

        function drawCover(img, dx, dy, dw, dh) {
          const ir = img.naturalWidth / img.naturalHeight;
          const br = dw / dh;
          let sx, sy, sw, sh;
          if (ir > br) {
            sh = img.naturalHeight;
            sw = sh * br;
            sx = (img.naturalWidth - sw) / 2;
            sy = 0;
          } else {
            sw = img.naturalWidth;
            sh = sw / br;
            sx = 0;
            sy = (img.naturalHeight - sh) / 2;
          }
          ctx.drawImage(img, sx, sy, sw, sh, dx, dy, dw, dh);
        }

        function drawContain(img, dx, dy, dw, dh, fill) {
          ctx.fillStyle = fill;
          ctx.fillRect(dx, dy, dw, dh);
          const ir = img.naturalWidth / img.naturalHeight;
          const br = dw / dh;
          let rw, rh;
          if (ir > br) { rw = dw; rh = dw / ir; } else { rh = dh; rw = dh * ir; }
          ctx.drawImage(img, dx + (dw - rw) / 2, dy + (dh - rh) / 2, rw, rh);
        }

        function roundRectPath(x, y, w, h, r) {
          const rr = Math.max(0, Math.min(r, Math.min(w, h) / 2));
          ctx.beginPath();
          ctx.moveTo(x + rr, y);
          ctx.lineTo(x + w - rr, y);
          ctx.quadraticCurveTo(x + w, y, x + w, y + rr);
          ctx.lineTo(x + w, y + h - rr);
          ctx.quadraticCurveTo(x + w, y + h, x + w - rr, y + h);
          ctx.lineTo(x + rr, y + h);
          ctx.quadraticCurveTo(x, y + h, x, y + h - rr);
          ctx.lineTo(x, y + rr);
          ctx.quadraticCurveTo(x, y, x + rr, y);
          ctx.closePath();
        }

        // Returns the rendered logo/panel box in canvas coordinates.
        function logoBox() {
          if (!images.logo) return null;
          const logoW = state.logoW;
          const logoH = Math.round(logoW * (images.logo.naturalHeight / images.logo.naturalWidth));
          const panelPad = state.panel ? state.panelPad : 0;
          const boxW = logoW + panelPad * 2;
          const boxH = logoH + panelPad * 2;
          const cx = (state.logoX / 100) * state.W;
          const cy = (state.logoY / 100) * state.H;
          const x = Math.round(cx - boxW / 2);
          const y = Math.round(cy - boxH / 2);
          return { x, y, w: boxW, h: boxH, logoW, logoH, panelPad };
        }

        function render() {
          canvas.width = state.W;
          canvas.height = state.H;
          ctx.clearRect(0, 0, state.W, state.H);
          ctx.fillStyle = state.bgFill;
          ctx.fillRect(0, 0, state.W, state.H);

          if (images.bg) {
            if (state.fit === 'cover') drawCover(images.bg, 0, 0, state.W, state.H);
            else drawContain(images.bg, 0, 0, state.W, state.H, state.bgFill);
          }

          const box = logoBox();
          if (box) {
            if (state.panel) {
              if (state.panelShadow) {
                ctx.save();
                ctx.fillStyle = 'rgba(26,18,8,0.35)';
                roundRectPath(box.x + 3, box.y + 3, box.w, box.h, state.panelRound);
                ctx.fill();
                ctx.restore();
              }
              ctx.fillStyle = state.panelBg;
              roundRectPath(box.x, box.y, box.w, box.h, state.panelRound);
              ctx.fill();
              if (state.panelBorderW > 0) {
                ctx.lineWidth = state.panelBorderW;
                ctx.strokeStyle = state.panelBorder;
                roundRectPath(box.x, box.y, box.w, box.h, state.panelRound);
                ctx.stroke();
              }
            }
            if (images.logo) {
              ctx.drawImage(images.logo, box.x + box.panelPad, box.y + box.panelPad, box.logoW, box.logoH);
            }
          }
        }

        // --- Controls wiring ---
        function bindRange(id, key, transform) {
          const el = $(id);
          const valEl = $(id + '-val');
          const upd = () => {
            const v = transform ? transform(el.value) : parseFloat(el.value);
            state[key] = v;
            if (valEl) valEl.textContent = String(v);
            render();
          };
          el.addEventListener('input', upd);
          upd();
        }
        function bindCheckbox(id, key) {
          const el = $(id);
          el.addEventListener('change', () => { state[key] = el.checked; render(); });
          state[key] = el.checked;
        }
        function bindColor(id, key) {
          const el = $(id);
          el.addEventListener('input', () => { state[key] = el.value; render(); });
          state[key] = el.value;
        }
        function bindNumber(id, key) {
          const el = $(id);
          el.addEventListener('input', () => { state[key] = parseFloat(el.value) || 0; render(); });
          state[key] = parseFloat(el.value) || 0;
        }
        function bindSelect(id, key, after) {
          const el = $(id);
          el.addEventListener('change', () => { state[key] = el.value; if (after) after(); render(); });
          state[key] = el.value;
        }

        bindSelect('bg-src', 'bgSrc', loadBg);
        bindSelect('logo-src', 'logoSrc', loadLogo);
        bindNumber('canvas-w', 'W');
        bindNumber('canvas-h', 'H');
        bindSelect('fit-mode', 'fit');
        bindColor('bg-fill', 'bgFill');
        bindRange('logo-w', 'logoW');
        bindRange('logo-x', 'logoX');
        bindRange('logo-y', 'logoY');
        bindCheckbox('panel-on', 'panel');
        bindRange('panel-pad', 'panelPad');
        bindColor('panel-bg', 'panelBg');
        bindColor('panel-border', 'panelBorder');
        bindRange('panel-border-w', 'panelBorderW');
        bindCheckbox('panel-shadow', 'panelShadow');
        bindRange('panel-round', 'panelRound');

        // --- Dragging ---
        let drag = null;
        function canvasCoords(ev) {
          const rect = canvas.getBoundingClientRect();
          const scaleX = state.W / rect.width;
          const scaleY = state.H / rect.height;
          const p = ev.touches ? ev.touches[0] : ev;
          return { x: (p.clientX - rect.left) * scaleX, y: (p.clientY - rect.top) * scaleY };
        }
        canvas.addEventListener('pointerdown', (ev) => {
          const box = logoBox();
          if (!box) return;
          const { x, y } = canvasCoords(ev);
          if (x >= box.x && x <= box.x + box.w && y >= box.y && y <= box.y + box.h) {
            drag = { offX: x - (box.x + box.w / 2), offY: y - (box.y + box.h / 2) };
            canvas.classList.add('dragging');
            canvas.setPointerCapture(ev.pointerId);
            ev.preventDefault();
          }
        });
        canvas.addEventListener('pointermove', (ev) => {
          if (!drag) return;
          const { x, y } = canvasCoords(ev);
          let nx = ((x - drag.offX) / state.W) * 100;
          let ny = ((y - drag.offY) / state.H) * 100;
          if (ev.shiftKey) { nx = Math.round(nx); ny = Math.round(ny); }
          nx = Math.max(0, Math.min(100, nx));
          ny = Math.max(0, Math.min(100, ny));
          state.logoX = nx;
          state.logoY = ny;
          $('logo-x').value = nx.toFixed(1);
          $('logo-y').value = ny.toFixed(1);
          $('logo-x-val').textContent = nx.toFixed(1);
          $('logo-y-val').textContent = ny.toFixed(1);
          render();
        });
        canvas.addEventListener('pointerup', () => { drag = null; canvas.classList.remove('dragging'); });
        canvas.addEventListener('pointercancel', () => { drag = null; canvas.classList.remove('dragging'); });

        // --- Save / Download ---
        function toBlob() {
          return new Promise((res) => canvas.toBlob((b) => res(b), 'image/png'));
        }
        const statusEl = $('status');
        const saveBtn = $('save-btn');
        const downloadBtn = $('download-btn');

        saveBtn.addEventListener('click', async () => {
          statusEl.className = 'status';
          statusEl.textContent = 'Saving...';
          saveBtn.disabled = true;
          try {
            const blob = await toBlob();
            const filename = $('save-filename').value;
            const res = await fetch('/api/save-kiddycody-hero?filename=' + encodeURIComponent(filename), {
              method: 'POST',
              headers: { 'content-type': 'image/png' },
              body: blob,
            });
            if (!res.ok) throw new Error((await res.text()) || ('HTTP ' + res.status));
            const data = await res.json();
            statusEl.className = 'status ok';
            statusEl.textContent = 'Saved ' + (data.bytes / 1024).toFixed(1) + ' KB to ' + filename;
          } catch (e) {
            statusEl.className = 'status err';
            statusEl.textContent = 'Save failed: ' + (e && e.message ? e.message : e) + ' (only works in `pnpm dev`)';
          } finally {
            saveBtn.disabled = false;
          }
        });

        downloadBtn.addEventListener('click', async () => {
          const blob = await toBlob();
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = $('save-filename').value;
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
          URL.revokeObjectURL(url);
        });

        // --- Init ---
        Promise.all([loadBg(), loadLogo()]).then(render);
      })();
    </script>
  </body>
</html>
