---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Not Found" description="Page not found.">
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <h1 class="mb-2 text-6xl font-extrabold tracking-tight text-[var(--color-muted)]">404</h1>
    <p class="mb-6 text-lg text-[var(--color-muted)]">Page not found.</p>
    <a
      href="/"
      class="rounded-lg bg-[var(--color-accent)] px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-[var(--color-accent-hover)]"
    >
      Go home
    </a>
  </div>
</BaseLayout>
