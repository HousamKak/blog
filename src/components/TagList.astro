---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---
{tags.length > 0 && (
  <div class="flex flex-wrap gap-1.5">
    {tags.map(tag => (
      <a
        href={`/tags/${tag}/`}
        class="bg-[var(--color-surface)] px-2.5 py-0.5 text-xs font-medium text-[var(--color-muted)] transition-colors hover:bg-[var(--color-surface-hover)] hover:text-[var(--color-text)]"
        style="border-radius: var(--radius-lg);"
      >
        {tag}
      </a>
    ))}
  </div>
)}
