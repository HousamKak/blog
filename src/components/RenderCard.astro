---
interface Props {
  id: string;
  title: string;
  thumbnail: string;
  mediaType: '2d' | '3d' | 'interactive';
  software?: string;
}

const { id, title, thumbnail, mediaType, software } = Astro.props;
const badge = mediaType === 'interactive' ? 'LIVE' : mediaType.toUpperCase();
---
<a href={`/renders/${id}/`} class="group block overflow-hidden border transition-colors hover:border-[var(--color-muted)]" style={`border-color: var(--color-border); border-width: var(--border-w); border-radius: var(--radius-xl); box-shadow: var(--shadow-card);`}>
  <div class="relative aspect-square overflow-hidden bg-[var(--color-surface)]">
    <img
      src={thumbnail}
      alt={title}
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
      loading="lazy"
    />
    <span class="absolute right-2 top-2 rounded-md bg-black/60 px-2 py-0.5 text-xs font-medium uppercase text-white backdrop-blur-sm">
      {badge}
    </span>
  </div>
  <div class="p-3">
    <h3 class="text-sm font-semibold transition-colors group-hover:text-[var(--color-accent)]">
      {title}
    </h3>
    {software && (
      <p class="mt-0.5 text-xs text-[var(--color-muted)]">{software}</p>
    )}
  </div>
</a>
