---
interface Props {
  id: string;
  title: string;
  description: string;
  thumbnail: string;
}

const { id, title, description, thumbnail } = Astro.props;
---
<a href={`/renders/library/${id}/`} class="group block overflow-hidden border transition-colors hover:border-[var(--color-muted)]" style={`border-color: var(--color-border); border-width: var(--border-w); border-radius: var(--radius-xl); box-shadow: var(--shadow-card);`}>
  <div class="relative aspect-video overflow-hidden bg-[var(--color-surface)]">
    <img
      src={thumbnail}
      alt={title}
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
      loading="lazy"
    />
    <span class="absolute right-2 top-2 rounded-md bg-black/60 px-2 py-0.5 text-xs font-medium uppercase text-white backdrop-blur-sm">
      interactive
    </span>
  </div>
  <div class="p-3">
    <h3 class="text-sm font-semibold transition-colors group-hover:text-[var(--color-accent)]">
      {title}
    </h3>
    <p class="mt-0.5 text-xs text-[var(--color-muted)] line-clamp-2">{description}</p>
  </div>
</a>
