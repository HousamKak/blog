---
const year = new Date().getFullYear();
---
<footer class="mt-auto border-t border-[var(--color-border)] py-8">
  <div class="mx-auto flex max-w-4xl flex-col items-center gap-3 px-4 text-sm text-[var(--color-muted)]">
    <div class="flex gap-4">
      <a href="/rss.xml" class="transition-colors hover:text-[var(--color-text)]">RSS</a>
      <a href="/tags/" class="transition-colors hover:text-[var(--color-text)]">Tags</a>
      <a href="/about/" class="transition-colors hover:text-[var(--color-text)]">About</a>
    </div>
    <p>&copy; {year} Housam.</p>
  </div>
</footer>
