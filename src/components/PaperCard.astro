---
import FormattedDate from './FormattedDate.astro';
import TagList from './TagList.astro';

interface Props {
  id: string;
  title: string;
  description: string;
  pubDate: Date;
  authors: string[];
  venue?: string;
  pdfUrl: string;
  tags: string[];
}

const { id, title, description, pubDate, authors, venue, pdfUrl, tags } = Astro.props;
---
<article class="group border p-5 transition-colors hover:border-[var(--color-muted)]" style={`border-color: var(--color-border); border-width: var(--border-w); border-radius: var(--radius-xl); box-shadow: var(--shadow-card);`}>
  <a href={`/papers/${id}/`} class="block">
    <h3 class="mb-1.5 text-lg font-semibold transition-colors group-hover:text-[var(--color-accent)]">
      {title}
    </h3>
    <p class="mb-2 text-sm text-[var(--color-muted)]">
      {authors.join(', ')}
      {venue && <span> &mdash; {venue}</span>}
    </p>
    <p class="mb-3 text-sm text-[var(--color-muted)] line-clamp-2">{description}</p>
  </a>
  <div class="flex items-center justify-between gap-3">
    <div class="flex items-center gap-3">
      <span class="text-xs text-[var(--color-muted)]">
        <FormattedDate date={pubDate} />
      </span>
      <a
        href={pdfUrl}
        target="_blank"
        rel="noopener"
        class="text-xs font-medium text-[var(--color-accent)] transition-colors hover:text-[var(--color-accent-hover)]"
      >
        PDF
      </a>
    </div>
    <TagList tags={tags} />
  </div>
</article>
