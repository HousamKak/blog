---
interface Props {
  url: string;
  title?: string;
}

const { url, title = 'PDF Document' } = Astro.props;
---
<div class="my-6">
  <iframe
    src={url}
    title={title}
    class="w-full rounded-lg border border-[var(--color-border)]"
    style="height: 80vh;"
    loading="lazy"
  ></iframe>
  <div class="mt-3 flex justify-end">
    <a
      href={url}
      download
      class="inline-flex items-center gap-1.5 rounded-lg border border-[var(--color-border)] px-3 py-1.5 text-sm font-medium transition-colors hover:bg-[var(--color-surface)]"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
      </svg>
      Download PDF
    </a>
  </div>
</div>
