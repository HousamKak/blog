---
import { getCollection } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
  /** Optional edition header shown above the collage (used by archive pages) */
  editionLabel?: string;
  editionTitle?: string;
  editionTagline?: string;
  editionDate?: Date;
}

const { editionLabel, editionTitle, editionTagline, editionDate } = Astro.props;

// Sort: date desc, then reverse-alphabetical id for ties (matches deployed order)
const byDateDesc = (a: any, b: any) => {
  const d = b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  return d !== 0 ? d : b.id.localeCompare(a.id);
};

const recentPosts = (await getCollection('posts')).filter(p => !p.data.draft).sort(byDateDesc);
const recentPapers = (await getCollection('papers')).filter(p => !p.data.draft).sort(byDateDesc);
const recentRenders = (await getCollection('renders')).filter(r => !r.data.draft).sort(byDateDesc);
const interactiveRenders = recentRenders.filter(r => r.data.mediaType === 'interactive');
const recentNotes = (await getCollection('notes')).filter(n => !n.data.draft).sort(byDateDesc);

const lede = recentPosts[0];
const secondary = recentPosts[1];
const tertiary = recentPosts[2];

const horoscopes = [
  { sign: 'Aries', text: 'Expect a 500-line diff from a stranger. Accept it. Read it twice.' },
  { sign: 'Taurus', text: 'A semicolon will betray you. Forgive it.' },
  { sign: 'Gemini', text: 'Two conflicting opinions about CSS will both be correct today.' },
  { sign: 'Cancer', text: 'A forgotten branch stirs. Prune it before midnight.' },
  { sign: 'Leo', text: 'The production build is watching. Act accordingly.' },
];

const obits = [
  { name: 'Internet Explorer 6', years: '2001–2014', note: 'Finally. Survived by regrets.' },
  { name: 'Flash Player', years: '1996–2020', note: 'Danced while it burned.' },
  { name: 'jQuery in new projects', years: '2006–2017', note: 'Still haunts legacy code.' },
];

const classifieds = [
  { head: 'WANTED', body: 'Junior typographer. Must appreciate ligatures. Apply in person with a kerning sample.' },
  { head: 'LOST', body: 'One semicolon, last seen near line 42. Reward offered. Do not attempt to compile without it.' },
  { head: 'FOR SALE', body: 'Lightly used regex. Matches everything, including things it should not. Runs fine.' },
  { head: 'PERSONAL', body: 'Dear algorithm — please stop recommending me my own posts. It is getting awkward. — H.' },
  { head: 'ANNOUNCEMENT', body: 'The ampersand society meets Tuesdays. Members encouraged to bring italics.' },
  { head: 'SERVICES', body: 'Will fix your tabs. Will not fix your spaces. Terms non-negotiable.' },
];
---
{(editionLabel || editionTitle) && (
  <header style="margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 3px double var(--ink-sumi);">
    {editionLabel && <div class="chaos-kicker" style="margin-bottom: 0.5rem;">{editionLabel}</div>}
    {editionTitle && <h1 style="font-family: var(--font-display); font-weight: 900; font-size: clamp(2rem, 4.5vw, 3.25rem); line-height: 1.05; margin: 0 0 0.4rem; letter-spacing: -0.02em;">{editionTitle}</h1>}
    {editionTagline && <p style="font-family: var(--font-body); font-style: italic; font-size: 1.1rem; color: var(--ink-muted); margin: 0 0 0.4rem;">&ldquo;{editionTagline}&rdquo;</p>}
    {editionDate && <div class="chaos-byline" style="margin: 0;"><FormattedDate date={editionDate} /></div>}
  </header>
)}

<section class="chaos-front">

  {lede && (
    <article class="chaos-card chaos-lede tilted-l" style="padding: 1.5rem 1.75rem 1.75rem;">
      <span class="tape tl" aria-hidden="true"></span>
      <span class="tape tr" aria-hidden="true"></span>

      <div style="display: flex; align-items: baseline; gap: 0.75rem; margin-bottom: 0.5rem;">
        <span class="ribbon">Breaking</span>
        <div class="chaos-kicker" style="border: none; margin: 0; padding: 0;">{(lede.data.tags || []).slice(0,2).join(' · ').toUpperCase() || 'DISPATCH'}</div>
      </div>

      <h1 class="chaos-head-xl" id="lede-title">
        <a href={`/posts/${lede.id}/`} style="color: inherit; text-decoration: none;">{lede.data.title}</a>
      </h1>

      <p class="chaos-deck">{lede.data.description}</p>

      {lede.data.heroImage && (
        <figure style="margin: 0.5rem 0 0.75rem;">
          <img src={lede.data.heroImage} alt="" style="width: 100%; height: auto; display: block; filter: sepia(0.12) saturate(0.9); border: 1px solid var(--color-hairline);" />
          <figcaption style="font-family: var(--font-smallcaps); font-size: 0.65rem; letter-spacing: 0.15em; color: var(--ink-muted); padding-top: 0.45rem; text-align: center;">
            FILED UNDER {(lede.data.tags || []).map(t => t.toUpperCase()).join(' · ') || 'CORRESPONDENCE'}
          </figcaption>
        </figure>
      )}

      <div class="chaos-byline">By Housam Kak &bull; <FormattedDate date={lede.data.pubDate} /></div>

      <div class="continued">Continues on page 2</div>
    </article>
  )}

  <aside class="chaos-aside-stack">
    <div class="chaos-card tilted-r" style="padding: 1rem 1.15rem;">
      <div class="chaos-kicker">At a glance</div>
      <ul style="list-style: none; padding: 0; margin: 0; font-family: var(--font-typewriter); font-size: 0.82rem; line-height: 1.55;">
        <li style="display: flex; justify-content: space-between; padding: 0.2rem 0; border-bottom: 1px dotted var(--color-hairline);"><span>Posts published</span><span>{recentPosts.length}</span></li>
        <li style="display: flex; justify-content: space-between; padding: 0.2rem 0; border-bottom: 1px dotted var(--color-hairline);"><span>Papers filed</span><span>{recentPapers.length}</span></li>
        <li style="display: flex; justify-content: space-between; padding: 0.2rem 0; border-bottom: 1px dotted var(--color-hairline);"><span>Notes scribbled</span><span>{recentNotes.length}</span></li>
        <li style="display: flex; justify-content: space-between; padding: 0.2rem 0; border-bottom: 1px dotted var(--color-hairline);"><span>Interactive renders</span><span>{interactiveRenders.length}</span></li>
        <li style="display: flex; justify-content: space-between; padding: 0.2rem 0;"><span>Regrets</span><span>0</span></li>
      </ul>
    </div>

    <div class="chaos-card tilted-l" style="padding: 1rem 1.15rem;">
      <span class="tape tr" aria-hidden="true"></span>
      <div class="chaos-kicker blue">Horoscope for Programmers</div>
      <div style="font-family: var(--font-body); font-size: 0.9rem; line-height: 1.5;">
        {horoscopes.map(h => (
          <p style="margin: 0 0 0.55rem;"><strong style="font-family: var(--font-smallcaps); letter-spacing: 0.08em; font-size: 0.8rem;">{h.sign.toUpperCase()}.</strong> {h.text}</p>
        ))}
      </div>
    </div>

    <div class="chaos-ad">
      <div class="chaos-ad-sub">est. 1911 &bull; &nbsp; an establishment</div>
      <div class="chaos-ad-title">Goudy &amp; Co.</div>
      <div class="chaos-ad-sub">Purveyors of fine ampersands</div>
      <div style="margin-top: 0.4rem; font-family: var(--font-handwriting); color: var(--ink-red); font-size: 1.3rem;">"Now with open bowls"</div>
    </div>
  </aside>

  {secondary && (
    <article class="chaos-card chaos-row-split-7 tilted-r" style="padding: 1.2rem 1.35rem; display: flex; flex-direction: column;">
      <span class="tape bl" aria-hidden="true"></span>
      <span class="pushpin" aria-hidden="true"></span>
      <div class="chaos-kicker yellow">Section II &bull; Feature</div>
      <h2 class="chaos-head-lg">
        <a href={`/posts/${secondary.id}/`} style="color: inherit; text-decoration: none;">{secondary.data.title}</a>
      </h2>
      <p class="chaos-deck">{secondary.data.description}</p>

      {secondary.data.heroImage ? (
        <figure style="margin: 0.25rem 0 0.5rem;">
          <img src={secondary.data.heroImage} alt="" style="width: 100%; height: auto; display: block; filter: sepia(0.12) saturate(0.9); border: 1px solid var(--color-hairline);" />
        </figure>
      ) : (
        <div style="margin: 0.25rem 0 0.5rem; padding: 0.85rem 1rem; border: 1px solid var(--color-hairline); background: var(--paper-aged); font-family: var(--font-typewriter); font-size: 0.85rem; line-height: 1.45; color: var(--ink-sumi);">
          <span style="font-family: var(--font-smallcaps); font-size: 0.65rem; letter-spacing: 0.15em; color: var(--ink-red);">EDITOR'S NOTE &mdash;&nbsp;</span>
          Filed under {(secondary.data.tags || []).map((t: string) => t.toUpperCase()).join(' · ') || 'CORRESPONDENCE'}. Turn inside for the full dispatch.
        </div>
      )}

      <div style="flex: 1;"></div>
      <div class="chaos-byline" style="margin-top: 0.5rem;">By Housam Kak &bull; <FormattedDate date={secondary.data.pubDate} /></div>
    </article>
  )}

  <div class="chaos-row-split-5" style="display: flex; flex-direction: column; gap: 1rem;">
    <div class="polaroid" style="transform: rotate(2.5deg);">
      <img src="/media/images/julia-sets-preview.png" alt="Julia set fractal" class="polaroid-img" style="object-fit: cover; filter: sepia(0.08) saturate(0.95);" />
      <div class="polaroid-caption">"the julia set, tuesday afternoon"</div>
    </div>
    <blockquote class="chaos-card tilted-l" style="padding: 1rem 1.15rem; font-family: var(--font-display); font-style: italic; font-weight: 500; font-size: 1.3rem; line-height: 1.4; margin: 0; position: relative;">
      <span style="position: absolute; top: 0.2rem; left: 0.4rem; font-family: var(--font-display); font-weight: 900; font-size: 3rem; color: var(--ink-red); opacity: 0.4; line-height: 1;">&ldquo;</span>
      <p style="margin: 0; padding-left: 1.75rem;">The proper response to bad typography is not silence.</p>
      <footer style="font-family: var(--font-smallcaps); font-size: 0.65rem; letter-spacing: 0.18em; color: var(--ink-muted); margin-top: 0.4rem; text-align: right;">&mdash; ANON, C. 1911</footer>
    </blockquote>
  </div>

  {tertiary && (
    <article class="chaos-card chaos-third tilted-l" style="padding: 1rem 1.15rem;">
      <div class="chaos-kicker">Also filed</div>
      <h3 class="chaos-head-md">
        <a href={`/posts/${tertiary.id}/`} style="color: inherit; text-decoration: none;">{tertiary.data.title}</a>
      </h3>
      <p style="font-family: var(--font-body); font-size: 0.95rem; line-height: 1.5; margin: 0 0 0.5rem;">{tertiary.data.description}</p>
      <div class="chaos-byline"><FormattedDate date={tertiary.data.pubDate} /></div>
    </article>
  )}

  <div class="chaos-card chaos-third tilted-r" style="padding: 1rem 1.15rem;">
    <div class="chaos-kicker">In memoriam</div>
    {obits.map(o => (
      <div style="padding: 0.4rem 0; border-bottom: 1px dashed var(--color-hairline);">
        <div style="font-family: var(--font-display); font-weight: 700; font-style: italic; font-size: 1.15rem; line-height: 1.15;">{o.name}</div>
        <div style="font-family: var(--font-smallcaps); font-size: 0.65rem; letter-spacing: 0.1em; color: var(--ink-muted);">{o.years}</div>
        <div style="font-family: var(--font-body); font-style: italic; font-size: 0.88rem; color: var(--ink-muted); margin-top: 0.15rem;">{o.note}</div>
      </div>
    ))}
  </div>

  {recentPapers[0] && (
    <article class="chaos-card chaos-third tilted-more" style="padding: 1rem 1.15rem;">
      <span class="tape tr" aria-hidden="true"></span>
      {recentPapers[0] && (
        <>
          <div class="chaos-kicker blue">Dispatched</div>
          <h3 class="chaos-head-md" style="font-family: var(--font-display); font-weight: 900;">
            <a href={`/papers/${recentPapers[0].id}/`} style="color: inherit; text-decoration: none;">{recentPapers[0].data.title}</a>
          </h3>
          <p style="font-family: var(--font-body); font-size: 0.88rem; line-height: 1.45; font-style: italic; color: var(--ink-muted); margin: 0;">{recentPapers[0].data.description.slice(0, 160)}&hellip;</p>
          <div class="continued" style="font-size: 0.72rem;">Filed in the papers desk</div>
        </>
      )}
    </article>
  )}

  <section class="chaos-card chaos-full" style="padding: 1rem 1.5rem 1.25rem;">
    <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 0.5rem;">
      <div class="chaos-head-script">Classifieds</div>
      <div style="font-family: var(--font-smallcaps); font-size: 0.7rem; letter-spacing: 0.18em; color: var(--ink-muted);">PAGE 7 &bull; &nbsp; POSTED BY VARIOUS</div>
    </div>
    <div class="classified">
      {classifieds.map(c => (
        <p><strong>{c.head} &mdash;</strong> {c.body}</p>
      ))}
    </div>
  </section>

  {recentNotes.length > 0 && (
    <section class="chaos-card chaos-full" style="padding: 0.9rem 1.25rem;">
      <div style="display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap;">
        <div class="chaos-kicker" style="border: none; padding: 0; margin: 0;">From the notebook</div>
        {recentNotes.slice(0, 6).map((n, i) => (
          <a href={`/notes/${n.id}/`} style={`font-family: var(--font-handwriting); color: ${i % 2 === 0 ? 'var(--ink-sumi)' : 'var(--ink-red)'}; font-size: 1rem; text-decoration: none; transform: rotate(${(i % 3 - 1) * 0.5}deg); display: inline-block;`}>
            {n.data.title}
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="chaos-card chaos-full tilted-l" style="padding: 1rem 1.5rem;">
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; text-align: center;">
      <div>
        <div class="chaos-kicker" style="border: none; padding: 0; margin: 0 0 0.25rem;">Today</div>
        <div style="font-family: var(--font-display); font-weight: 800; font-style: italic; font-size: 1.3rem;">Partly ironic</div>
        <div style="font-family: var(--font-smallcaps); font-size: 0.65rem; letter-spacing: 0.15em; color: var(--ink-muted);">20° C &bull; LIGHT DRIZZLE</div>
      </div>
      <div>
        <div class="chaos-kicker" style="border: none; padding: 0; margin: 0 0 0.25rem;">Tomorrow</div>
        <div style="font-family: var(--font-display); font-weight: 800; font-style: italic; font-size: 1.3rem;">Speculative</div>
        <div style="font-family: var(--font-smallcaps); font-size: 0.65rem; letter-spacing: 0.15em; color: var(--ink-muted);">22° C &bull; HIGH CONFIDENCE</div>
      </div>
      <div>
        <div class="chaos-kicker" style="border: none; padding: 0; margin: 0 0 0.25rem;">Thursday</div>
        <div style="font-family: var(--font-display); font-weight: 800; font-style: italic; font-size: 1.3rem;">Unverified</div>
        <div style="font-family: var(--font-smallcaps); font-size: 0.65rem; letter-spacing: 0.15em; color: var(--ink-muted);">19° C &bull; PENDING PEER REVIEW</div>
      </div>
      <div>
        <div class="chaos-kicker" style="border: none; padding: 0; margin: 0 0 0.25rem;">Friday</div>
        <div style="font-family: var(--font-display); font-weight: 800; font-style: italic; font-size: 1.3rem;">Deployed</div>
        <div style="font-family: var(--font-smallcaps); font-size: 0.65rem; letter-spacing: 0.15em; color: var(--ink-muted);">24° C &bull; NO ROLLBACK</div>
      </div>
    </div>
  </section>

</section>
